# Cluster-root gitignore.
# Secrets and state never enter VCS.

output.json
output.json.tmp
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfvars
!terraform.tfvars.example
.terraform/
.terraform.lock.hcl
*.tfplan
crash.log
crash.*.log
.tofu-test-history
# Per-VM Talos machineconfig files. These contain bootstrap tokens and certs.
# Regenerated by `tofu apply` (module writes them via local_sensitive_file).
talos/
talos/*.yaml
