vendored/
.env

# Local skills (kept on disk, not tracked in git)
.agents/skills/spec-bridge-*

# Worktrees (collapsed blanket ignore; per-WP entries no longer needed)
.worktrees/

# Image build (SS1) — gitignore the bake output but keep the source.
build/

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build artefacts (uv build -> dist/)
dist/
*.egg-info/

# Operational logs (scripts/apply.py, scripts/apply_cluster.py).
# Captured per-cluster tofu plan/apply output. NOT for CI upload.
logs/

# Editor / IDE
.vscode/
.idea/

# Local kubeconfigs generated by `kubeconfig-puller`; the
# operator regenerates them with the live tunnel on demand.
# Treat as build artefacts alongside the gitignored output.json.
infra/clusters/*/kubeconfig.pveproxy
infra/clusters/*/kubeconfig

# Coverage
.coverage
.tmp/

# OpenTofu / Terraform
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
.tofu-test-history

# Local tfvars (secrets-bearing; never tracked)
terraform.tfvars
*.tfvars
!*.tfvars.example

# One-shot pre-migration backups of terraform.tfstate before
# `tofu init -migrate-state` to a remote backend. Never track.
.local-state-backup-*/

# Per-cluster bootstrap state (regenerated on each bootstrap run)
infra/clusters/*/bootstrap_state.json
